// Landing Pages: páginas personalizadas opcionales

model Page {
  id        String   @id @default(cuid())
  tenantId  String
  title     String
  content   Json     // contenido de la página (bloques, HTML, etc.)
  slug      String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("pages")
}
